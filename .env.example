# Seven Test TUI Configuration

# Backend API endpoint (find in AWS API Gateway → Stages)
API_ENDPOINT=https://se7-int-dev.dev.api.playtheseven.com

# Cognito User Pool ID (find in AWS Cognito → User Pools)
USER_POOL_ID=eu-west-2_uqwEOLO5d

# Cognito App Client ID (find in AWS Cognito → User Pools → App Clients)
CLIENT_ID=your-client-id-here

# Environment prefix (e.g., int-dev, SE7-2001)
PREFIX=int-dev

# AWS Region
AWS_REGION=eu-west-2
